server {
    server_name mcp-nano-banana.mobiweb.pt;

    # MCP responses include base64 image data; allow large bodies.
    client_max_body_size 25M;

    location / {
        proxy_pass         http://127.0.0.1:3002;
        proxy_http_version 1.1;
        proxy_set_header   Upgrade           $http_upgrade;
        proxy_set_header   Connection        'upgrade';
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout 300s;
        proxy_send_timeout 300s;
        proxy_buffering    off;
    }

    listen 443 ssl;
    # ssl_certificate /etc/letsencrypt/live/mcp-nano-banana.mobiweb.pt/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/mcp-nano-banana.mobiweb.pt/privkey.pem;
    # include /etc/letsencrypt/options-ssl-nginx.conf;
    # ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;
}

server {
    if ($host = mcp-nano-banana.mobiweb.pt) {
        return 301 https://$host$request_uri;
    }
    listen 80;
    server_name mcp-nano-banana.mobiweb.pt;
    return 404;
}
